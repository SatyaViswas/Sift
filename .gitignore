# --- Cognee Local Database Storage ---
# This is crucial! Cognee creates these hidden folders to store your 
# Knowledge Graph, Vector index, and SQLite files locally. 
# Do not upload these to GitHub.
backend/.cognee_system/
backend/.data_storage/
backend/.cognee_cache/
.cognee_system/
.cognee_cache/

# --- Environment Secrets (Critical Security) ---
# Never upload your API keys
.env

